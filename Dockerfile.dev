# ==============================================
# Dockerfile.dev — Laravel Development Template
# PHP version ล็อคให้ตรงกับ Server
# ==============================================
FROM php:8.1-fpm-alpine

# ติดตั้ง PHP Extensions + เครื่องมือที่จำเป็น
RUN apk add --no-cache \
    git curl zip unzip bash mysql-client nodejs npm \
    libzip-dev freetype libpng libjpeg-turbo \
    freetype-dev libpng-dev libjpeg-turbo-dev \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install pdo_mysql gd zip bcmath \
    && apk del freetype-dev libpng-dev libjpeg-turbo-dev

# ติดตั้ง Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /var/www

# ก๊อปปี้ entrypoint script
COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 9000

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
